+        if (prev && prev.status === "completed") return json(200, { id, skipped: "completed_locked" });
+      }
+      await store.setJSON(id, record);
+    }
     catch (err) { console.error("Failed to save session", err); return json(502, { error: "save_failed" }); }
     return json(200, { id });
   }
